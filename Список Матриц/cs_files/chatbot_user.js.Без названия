SimpleChatbot.prototype._addConsultationRequest = function (thems_id, lawer_mail, message_history, state, head_mail) {
    var consultatioSend = JSON.stringify({
        thems_id: thems_id,
        lawer_mail: lawer_mail,
        message_history: message_history,
        state: state,
        user_fio: this._user_fio
    });

    var consultationRequest = new XMLHttpRequest();
    consultationRequest.onreadystatechange = function () {
        if (consultationRequest.readyState === 0 || consultationRequest.readyState === 4) {
            if (consultationRequest.status == 200) {
