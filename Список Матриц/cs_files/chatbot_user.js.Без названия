SimpleChatbot.prototype._changeStatusConsultation = function (_status) {
    var consultatioSend = JSON.stringify({
        message_history: localStorage.getItem('chatbot'),
        state: _status
    });

    var consultationRequest = new XMLHttpRequest();
    consultationRequest.onreadystatechange = function () {
        if (consultationRequest.readyState === 0 || consultationRequest.readyState === 4) {
            if (consultationRequest.status == 200) {
                //that._close = true;
                //console.log(JSON.parse(request.responseText));
            } else {
                //console.log('error');
            }
        }
    };
    var _req_id = this.request_id || window.localStorage.getItem('dialog_id');
    var url = this.host + '/chatbot/api/v1/consultation/' + _req_id + '/';
    var that = this;
    consultationRequest.open('PUT', url);
    const csrftoken = that.getCookie('csrftoken');
    consultationRequest.responseType = 'json';
    consultationRequest.setRequestHeader('X-CSRFToken', csrftoken);
    consultationRequest.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
    consultationRequest.setRequestHeader('Content-Type', 'application/json');

    consultationRequest.send(consultatioSend);
};
