};

// основной шаблон чат-бота
SimpleChatbot.createTemplate = function () {
    let $root = document.querySelector('.chatbot');
    if ($root) {
        return $root;
    }
    const $fragment = document.createElement('div');
    $fragment.className = 'chatbot chatbot_hidden';
    $fragment.innerHTML = '<div class="chatbot__title"><span class="chatbot__close"></span>Чат-бот<span class="chatbot__reset"></span></div><div class="chatbot__wrapper"><div class="chatbot__items"></div></div><div class="chatbot__footer"><input class="chatbot__input" type="text" ><button class="chatbot__submit" type="button" ></button></div>';
    document.body.appendChild($fragment);
    return document.querySelector('.chatbot');
};
