// шаблон chatbot__item
SimpleChatbot.templateItem = function (replicas) {
    let html = '<div class="chatbot__item chatbot__item_{{type}}"><div class="chatbot__content chatbot__content_{{type}}{{state}}">{{content}}</div></div>';
    html = html.replace('{{type}}', replicas.type);
    html = html.replace('{{type}}', replicas.type);
    html = html.replace('{{state}}', replicas.type === 'bot' ? '' : '-disabled');
    html = html.replace('{{content}}', replicas.content);
    return html;
};
//поиск ответа на произвольный вопрос
SimpleChatbot.prototype._outputContentHuman = function (question) {
    var that = this;

    if (question == "#botabout") {
        var newRepl = JSON.parse(window.localStorage.getItem('default_questions'));
        newRepl['bot']['800'] = {};
        newRepl['bot']['800']['content'] = "Версия: 100226v1.  collapse:" + window.localStorage.getItem('cb_collapse') + "; assessment:" + window.localStorage.getItem('cb_assessment');
        newRepl['bot']['800']['human'] = [];
        that._replicas = newRepl;
    } else {
        localStorage.setItem('chatbot_question', question);
        answer = this.host + '/chatbot/api/v1/mainview/search/?q=' + question;
        var allanswer = '';
        const requestAnsw = new XMLHttpRequest();

        requestAnsw.open('GET', answer, true);
        requestAnsw.responseType = 'json';
        requestAnsw.onload = function () {
            const statusAnsw = requestAnsw.status;
            if (statusAnsw === 200) {
                const dataAnswDirt = requestAnsw.response;
                if (typeof dataAnswDirt === 'string') {
                    answer = JSON.parse(dataAnswDirt);
                } else {
                    var newRepl = JSON.parse(window.localStorage.getItem('default_questions'));

                    var dataAnsw = [],
                    n = 0;
                    for (var i = 0; i < dataAnswDirt.length; i++) { //Фильтрация вопросов
                        if (dataAnswDirt[i].systems.includes(1)) {
                            dataAnswDirt[i].systems.push(Number(localStorage.getItem('cb_system'))); //если в репликах не указана система, то поумолчанию  считать, что система та, из которой совершается вызов
                        }
                        if (dataAnswDirt[i].systems.includes(Number(localStorage.getItem('cb_system')))) {
                            dataAnsw[n] = dataAnswDirt[i];
                            n++;
                        }
                    }
                    if (dataAnsw.length > 0) {

                        var cnt = -1,
                        topic = dataAnsw[0].topics;
                        var answr = [];
                        answr[0] = {};
                        answr[0]['content'] = 'Найдены похожие вопросы:';
                        answr[0]['human'] = [];

                        newRepl['bot']['800'] = {};
                        newRepl['bot']['800']['content'] = 'Найдены похожие вопросы:';
                        newRepl['bot']['800']['human'] = [];
                        for (var i = 0; i < dataAnsw.length; i++) {
                            topic = dataAnsw[i].topics;
                            cnt++;
                            try {

                                var num = '800' + String(dataAnsw[i].topics) + String(i);
                                newRepl['bot']['800']['human'][cnt] = num;
                                answr[0]['human'][cnt] = num;
                                newRepl['human'][num] = {};
                                newRepl['human'][num]['bot'] = [];
                                newRepl['human'][num]['bot'][0] = num;
                                newRepl['human'][num]['content'] = dataAnsw[i].question;
                                allanswer = allanswer + ';' + dataAnsw[i].question;
                                //ответ  бота
                                newRepl['bot'][num] = {};
                                newRepl['bot'][num]['content'] = dataAnsw[i].content;
                                //  newRepl['bot'][num]['human']=[0, 1, 2, 3, 4, 5, 6, 7];
                            } catch (e) {
                                console.log(e);
                            }
                        }
                    } else {
                        var not_answer = window.localStorage.getItem('not_answer');
                        newRepl['bot']['800'] = {};
                        newRepl['bot']['800']['content'] = not_answer || 'К сожалению, ничего не найдено. Попробуйте переформулировать вопрос или выберите тематику';
                        allanswer = "";
                        +newRepl['bot']['800']['content'];
                        newRepl['bot']['800']['human'] = [777, 0, 1, 2, 3, 4, 5, 6, 7]; //777 -  подключить специалиста
                        that._$root.querySelector('.chatbot__input').value = '';
                        window.localStorage.setItem('questions', JSON.stringify(answr));
                        window.localStorage.setItem('allanswer', allanswer.substr(1));
                        window.localStorage.setItem('chatbot_answer', 'Ответ не найден');
                        that._addLog('0');
                        that.botA = false;
                    }
                    that._replicas = newRepl;
                    window.localStorage.setItem('questions', JSON.stringify(answr));
                    window.localStorage.setItem('allanswer', allanswer.substr(1));
                    that.humanQ = true;
                }

            } else {
                console.log(statusAnsw, requestAnsw.response);
            }
        };
        requestAnsw.send();
    }

}
