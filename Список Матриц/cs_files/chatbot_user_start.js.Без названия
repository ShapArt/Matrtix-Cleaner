const requestSettings = new XMLHttpRequest();

requestSettings.open('GET', configChatbot.settings, true);
requestSettings.responseType = 'json';
requestSettings.onload = function () {
    const statusSettings = requestSettings.status;
    if (statusSettings === 200) {
        const dataSettings = requestSettings.response;
        if (typeof dataSettings === 'string') {
            configChatbot.settings = JSON.parse(dataSettings);
        } else {

            for (var i = 0; i < dataSettings.length; i++) {
                switch (dataSettings[i].name) {
                case 'collapse':
                    window.localStorage.setItem('cb_collapse', dataSettings[i].value);
                    break;
                case 'assessment':
                    window.localStorage.setItem('cb_assessment', dataSettings[i].value);
                    break;
				case 'notification':
                    window.localStorage.setItem('cb_notification', dataSettings[i].value);
                    break;
                }

            }

        }

    } else {
        console.log(statusSettings, requestSettings.response);
    }
};
