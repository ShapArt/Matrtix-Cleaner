var svrPfx;

function createMyBWSMenu( menuLabel, supportDir, serverPrefix )
{
	svrPfx = serverPrefix;
	
	if ( $("#MyBWSGlobalMenu").size() == 0 )
	{
		var Menu = '<li class="has-submenu" id="MyBWSGlobalMenu">';
			Menu += '<a href="#"><span class="topmenu">' + menuLabel + '<div class="topmenu-icon">&nbsp;</div></span></a>';
			Menu += '<ul id="ByBWSContent"><li><a><span class="globalMenuItem"><img width=16px height=16px src="' + supportDir + 'otsapxecm/indeterminate_circle16.gif"></span></a></li></ul>';
			Menu += '</li>';
			
			//Unfortunately this ID is not working for multilinguality: $("#ToolsGlobalMenu").after(Menu);
		$("#HelpGlobalMenu").before(Menu);
	
		$("#MyBWSGlobalMenu").mouseenter( populateMyBWSMenu );
	}	
}		

function populateMyBWSMenu( event ) 
{
	$("#MyBWSGlobalMenu").unbind("mouseenter", populateMyBWSMenu );

	var url = svrPfx + "?func=ll&objAction=favoritesmenu&objType=848&page=1&sort=name&nextURL=" + svrPfx;

	$.get( url, function( returnValue ) {
		options = {};
		options.columns =1;
		options.functionMenus = false;
		options.element = $('#ByBWSContent');
		options.continueTo = OTfunc._continueListItems;
		options.continueToValue = options;

		OTfunc.processLoadedNodes(returnValue, options);

		$("#MyBWSGlobalMenu").find("ul li a").wrapInner('<span class="globalMenuItem" />');
		$("#ByBWSContent li").replaceWith($("#MyBWSGlobalMenu").find(".ot_nodelist ul li"));
		$("#ByBWSContent").children().eq($("#ByBWSContent").children().length - 1).addClass('last-menu-item');
		$("#ByBWSContent").children(".last-menu-item").children("a").css("background-repeat","repeat-x");
		$("#ByBWSContent").children().width($("#ByBWSContent").width());
		$("#MyBWSGlobalMenu").find(".ot_nodelist").remove();
		
	});
}

