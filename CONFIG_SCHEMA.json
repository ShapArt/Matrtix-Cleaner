{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ShapArt/Matrtix-Cleaner/schema/config-v7.json",
  "title": "Matrix Cleaner DSL v6/v7",
  "description": "Единый JSON DSL: matrixQuery, selection, operation, preview, apply, checklist, report, rollbackHint. v7 keeps v6 operation compatibility and adds stronger verify/apply reporting.",
  "type": "object",
  "required": ["schemaVersion", "sourceMetadata"],
  "anyOf": [
    { "required": ["operations"] },
    { "required": ["operation"] }
  ],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^(2|6|7)\\.[0-9]+\\.[0-9]+$" },
    "sourceMetadata": {
      "type": "object",
      "required": ["requestId", "author", "createdAt"],
      "properties": {
        "requestId": { "type": "string", "minLength": 1 },
        "author": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "matrixQuery": { "type": "object", "additionalProperties": true },
    "selection": { "type": "object", "additionalProperties": true },
    "operation": { "type": "object", "additionalProperties": true },
    "safety": { "type": "object", "additionalProperties": true },
    "preview": { "type": "object", "additionalProperties": true },
    "apply": { "type": "object", "additionalProperties": true },
    "checklists": { "type": "object", "additionalProperties": true },
    "reporting": { "type": "object", "additionalProperties": true },
    "rollbackHint": { "type": "object", "additionalProperties": true },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "payload"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "replace_approver",
              "remove_approver",
              "replace_signer",
              "add_signer_bundle",
              "change_limits",
              "expand_legal_entities",
              "expand_sites",
              "patch_doc_types",
              "add_doc_type_to_matching_rows",
              "add_change_card_flag_to_matching_rows",
              "add_legal_entity_to_matching_rows",
              "remove_counterparty_from_rows",
              "delete_rows_if_single_counterparty",
              "find_counterparty_everywhere",
              "find_user_everywhere",
              "checklist_route_failure",
              "checklist_card_validation",
              "checklist_signing_rules",
              "matrix_audit"
            ]
          },
          "selection": { "type": "object", "additionalProperties": true },
          "payload": { "type": "object", "additionalProperties": true },
          "options": { "type": "object", "additionalProperties": true },
          "preview": { "type": "object", "additionalProperties": true },
          "apply": { "type": "object", "additionalProperties": true },
          "checklist": { "type": "object", "additionalProperties": true },
          "report": { "type": "object", "additionalProperties": true },
          "rollbackHint": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
