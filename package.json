{
  "name": "ot-matrix-automation",
  "version": "1.0.0",
  "description": "Тесты и окружение для userscript автоматизации матриц OpenText (Matrix Cleaner).",
  "private": true,
  "scripts": {
    "build": ".\\.bootstrap\\node\\node.exe scripts/build-userscript.mjs",
    "preflight": ".\\.bootstrap\\node\\node.exe scripts/preflight.mjs",
    "bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bootstrap-node.ps1",
    "inventory": ".\\.bootstrap\\node\\node.exe scripts/inventory-open-text-assets.mjs",
    "inventory:smoke": ".\\.bootstrap\\node\\node.exe scripts/inventory-smoke.mjs",
    "analyze:corpus": ".\\.bootstrap\\node\\node.exe scripts/analyze-open-text-patterns.mjs",
    "schema:validate": ".\\.bootstrap\\node\\node.exe scripts/validate-schema.mjs",
    "verify:dist": ".\\.bootstrap\\node\\node.exe scripts/verify-dist-parity.mjs",
    "test": ".\\.bootstrap\\node\\node.exe .\\node_modules\\@playwright\\test\\cli.js test",
    "test:e2e": ".\\.bootstrap\\node\\node.exe .\\node_modules\\@playwright\\test\\cli.js test tests/matrix-automation.spec.js tests/toolkit.spec.js",
    "test:unit": ".\\.bootstrap\\node\\node.exe --test tests/unit/*.test.js",
    "test:v8": ".\\.bootstrap\\node\\node.exe .\\node_modules\\@playwright\\test\\cli.js test --grep \"v8|60\\.|61\\.|62\\.|63\\.\"",
    "test:headed": ".\\.bootstrap\\node\\node.exe .\\node_modules\\@playwright\\test\\cli.js test --headed",
    "test:ui": ".\\.bootstrap\\node\\node.exe .\\node_modules\\@playwright\\test\\cli.js test --ui",
    "lint": ".\\.bootstrap\\node\\node.exe --check src/runtime/toolkit-core.js && .\\.bootstrap\\node\\node.exe --check src/runtime/v8-core.js && .\\.bootstrap\\node\\node.exe --check src/corpus/patterns.cjs && .\\.bootstrap\\node\\node.exe --check scripts/build-userscript.mjs && .\\.bootstrap\\node\\node.exe --check scripts/analyze-open-text-patterns.mjs",
    "typecheck": ".\\.bootstrap\\node\\node.exe --check src/presets/signer-forms.cjs && .\\.bootstrap\\node\\node.exe --check src/resolvers/legal-entity-resolver.cjs && .\\.bootstrap\\node\\node.exe --check src/core/context-detector.cjs && .\\.bootstrap\\node\\node.exe --check src/corpus/patterns.cjs",
    "verify:core": ".\\.bootstrap\\node\\npm.cmd run preflight && .\\.bootstrap\\node\\npm.cmd run test:unit && .\\.bootstrap\\node\\npm.cmd run schema:validate && .\\.bootstrap\\node\\npm.cmd run inventory:smoke && .\\.bootstrap\\node\\npm.cmd run analyze:corpus && .\\.bootstrap\\node\\npm.cmd run build && .\\.bootstrap\\node\\npm.cmd run verify:dist",
    "verify": ".\\.bootstrap\\node\\npm.cmd run verify:core && .\\.bootstrap\\node\\npm.cmd test",
    "test:all": ".\\.bootstrap\\node\\npm.cmd run verify",
    "smoke": ".\\.bootstrap\\node\\npm.cmd run verify:core && .\\.bootstrap\\node\\node.exe .\\node_modules\\@playwright\\test\\cli.js test -g \"smoke|1\\. detects matrix list page|42\\. end-to-end smoke flow|toolkit\""
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "ajv": "^8.17.1"
  }
}
