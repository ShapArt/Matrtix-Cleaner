	card: {
		checkRequiredFields: function (element, msg){
			var emptyFields = [];
			//Validate partnerSet if exist
			if (sc_partnerSet.validate){
				emptyFields = sc_partnerSet.validate();
			}

			$('.sc_requiredField:visible', $(element)).each(function (idx, label){
				var $el = $(label);
				var $elTitle = $el.attr('title');
				if ($elTitle){
					$el.find('input').each(function (idx, field){
						if (!field.value || field.value == sc.emptyFieldDecorator){
							emptyFields.push($elTitle);
						}
					});
				}else{
					$el.parent().next().find('input').each(function (idx, field){
						if (!field.value || field.value == sc.emptyFieldDecorator){
							emptyFields.push($.trim($el.parent().text()));
						}
					});
				}
			});

			if (emptyFields.length == 0){
				return true;
			}else{
				alert(msg + "\r\n" + emptyFields.join("\r"));
				return false;
			}
		},
		tabReload: function (tabIdx){
			var $tabs = $('#ztabs');

			if (!tabIdx){
				tabIdx = $tabs.tabs('option', 'active');
			}

			//$($tabs.data('uiTabs').tabs[tabIdx]).removeData("cache.tabs");
			$('[aria-labelledby="ui-id-'+tabIdx+'"]').removeData("cache.tabs");
			$($tabs.data('uiTabs').panels[tabIdx]).empty();
			$tabs.tabs('load', tabIdx);
		},
		tabChangeUrl: function(tabIdx, newUrl){
			var $tabs = $('#ztabs');

			if (!tabIdx){
				tabIdx = $tabs.tabs('option', 'active');
			}

			//$($tabs.data('uiTabs').tabs[tabIdx]).find('a:first').attr('href', newUrl);
			$('[aria-selected="true"]').find('a:first').attr('href', newUrl);
			this.tabMarkAsLoading(tabIdx);
			this.tabReload(tabIdx);
		},
		tabGetUrl: function(tabIdx){
			var $tabs = $('#ztabs');

			if (!tabIdx){
				tabIdx = $tabs.tabs('option', 'active');
			}

			//return $($tabs.data('uiTabs').tabs[tabIdx]).find('a:first').attr('href');
			return $('[aria-selected="true"]').find('a:first').attr('href');
		},
		tabMarkAsLoading: function (tab){
			var $tabs = $('#ztabs');

			if(!$tabs.length){
				return false;
			}
			if (!tab){
				tab = $tabs.tabs('option', 'active');
			}
			tab--;
			$($tabs.data('uiTabs').panels[tab])
				.html('<p style="text-align: center"><img src="' + sc.supportPrefix + 'circleecm_progmeter40x40.gif" border="0" /></p>');
			return true;
		}
