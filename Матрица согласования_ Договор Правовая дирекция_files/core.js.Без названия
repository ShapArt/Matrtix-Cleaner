		setSort: function (field, isAsc){
			var node = $('thead a', '.sc_rResult').filter('[onclick*="' + field + '"]');
			if (!node){
				return false;
			}
			node.append($('<img src="' + sc.supportPrefix + 'sort-' + (isAsc == 'true' ? 'up' : 'down') + '.gif" border="0" style="margin-left:5px">'));
