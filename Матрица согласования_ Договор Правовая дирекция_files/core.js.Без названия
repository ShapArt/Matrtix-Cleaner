		selectOP: function(rowIdx, catId, partnerId, fieldName, docID) {
			var invalidValues = [];
			$(".partner_" + partnerId).not("#bopview_" + rowIdx).find("div").each (function() {
				if ($(this).html() != "") {
					invalidValues.push($(this).html());
				}
			});
			var request = {
				"func": "zdoc.GetTableLookupDialog",
				"catID": catId,
				"attrAlias": "partner_op",
				"partnerID": partnerId
			}
			if (docID > 0) {
				request.docID = docID;
			}
			$.getJSON(sc.urlPrefix, request, function (data){
				if (data.status == "success") {
					var $list = $("#op_list").html("");
					var chosen = [];
					$(".ophid_" + rowIdx).each(function(){
							chosen.push($(this).val());
					});
					
					for (var i = 0; i < data.validList.length; i++) {
						$list.append('<li><label><input class="chosen" type="checkbox" value="' + data.validList[i] + '"' +
							(chosen.indexOf(data.validList[i]) >= 0 ? ' checked="checked"' : '') +
							(data.docValues && data.docValues.indexOf(data.validList[i]) < 0 || invalidValues.indexOf(data.validList[i]) >= 0 ? ' disabled="disabled"' : '') +
							'>' + data.validList[i] + '</label></li>');
					}
					$("#select_op").dialog({
						modal: true,
						title: "Выберите значения (Обособленное подразделение)",
						buttons: {
							"Выбрать": function() {
								var checked = [];
								$("#op_list").find('input:checked:enabled').each(function(){
									checked.push($(this).val());
								})
								for (var i = 1; i <= chosen.length; i++) {
									$("#opview_" + rowIdx + "_" + i).remove();
									$("#ophid_" + rowIdx + "_" + i).remove();
								}
								for (var i = 1; i <= checked.length; i++) {
									$("#bopview_" + rowIdx).append('<div id="opview_' + rowIdx + '_' + i + '">' + checked[i-1] + '</div>');
									$("#bophid_" + rowIdx).append('<input class="ophid_' + rowIdx + '" id="ophid_' + rowIdx + '_' + i + '" type="hidden" value="' + checked[i-1] + '" />');
								}
								if ($(".ophid_" + rowIdx).length == 0) {
									$("#bopview_" + rowIdx).append('<div id="opview_' + rowIdx + '_1"></div>');
									$("#bophid_" + rowIdx).append('<input class="ophid_' + rowIdx + '" id="ophid_' + rowIdx + '_1" type="hidden" value="" />');
								}
								
								var i = 1;
								$(".ophid_" + rowIdx).each(function(){
									$(this).attr("name", fieldName + i);
									$(this).attr("id", "ophid_" + rowIdx + "_" + i);
									i += 1;
								});
								i = 1;
								$("bopview_" + rowIdx).find("div").each(function(){
									$(this).attr("id", "opview_" + rowIdx + "_" + i);
									i += 1
								});
								$(this).dialog("close");
							}
						}
					})
				} else {
					alert(data.ErrMsg);
				}
			});
		}
		
	},
