		checkApprovalFields: function (mainContractID, callback){
			$.ajax({
				url: sc.urlPrefix,
				dataType: 'json',
				data: {
					'func': 'zdoc.CheckNotActing',
					'DataID': mainContractID
				}
			})
			.done(function(){
				$.getJSON(sc.urlPrefix, {
					'func': 'zdoc.CheckRequiredFields',
					'DataID': mainContractID
				}, function (data){
					if (data.status != 'success'){
						if (callback){
							callback(data.ErrMsg, false);
						}
						return;
					}
					$(".sc_invalid").removeClass('sc_invalid');
					$(".sc_invalid_filed").removeClass('.sc_invalid_filed');
					var question = false
					var retMsg = '';
					if (data.Errors && data.Errors.length){
						for (var i = 0; i < data.Errors.length; i++){
							var obj = data.Errors[i];
							retMsg += obj.error + '\r';
							if(data.Errors[i].id){
								var id = data.Errors[i].id.split('.');
								if($("[name*=scAttr" + id[0] + "_1_" + id[1] + "_" + id[2] + ']').parent('td')[0]){
									$("[name*=scAttr" + id[0] + "_1_" + id[1] + "_" + id[2] + ']').parent('td').prev().addClass("sc_invalid_filed");
									$("[name*=scAttr" + id[0] + "_1_" + id[1] + "_" + id[2] + ']').parent('td').addClass("sc_invalid_filed");
								}
								//if($("[class*=scAttr" + id[0] + "_1_" + id[1] + "_" + id[2] + ']').parent('td')[0]){
								//	$("[class*=scAttr" + id[0] + "_1_" + id[1] + "_" + id[2] + ']').parent('td').prev().addClass("sc_invalid_filed");
								//}
								//$("[name*=scAttr" + id[0] + "_1_" + id[1] + "_" + id[2] + ']').parent('td').addClass("sc_invalid_filed");
								//$("[class*=scAttr" + id[0] + "_1_" + id[1] + "_" + id[2] + ']').parent('td').addClass("sc_invalid_filed");
							}
							if(data.Errors[i].separate_division){
								$('.sc_partnerSetRowID[value=' + data.Errors[i].separate_division + ']').parent('td').siblings('.sc_partnerSetRowOP').first().addClass("sc_invalid_filed");
							}
							if(data.Errors[i].check_status){
								$('.sc_partnerSetRowID[value=' + data.Errors[i].check_status + ']').parent('td').siblings('.sc_partnerSetRowStatus').first().addClass("sc_invalid_filed");
							}
							if(data.Errors[i].few_partners){
								if($('#sc_partnerInternalSet thead tr').first()[0]){
									$('#sc_partnerInternalSet thead tr').first().find('td').addClass("sc_invalid_filed");
								} else{
									$('#sc_partnerSet thead tr').first().find('td').addClass("sc_invalid_filed");
								}
							}
							if (data.Errors[i].empty_org_set) {
								$('#sc_partnerSet thead tr').first().find('td').addClass("sc_invalid_filed");
							}
							if (data.Errors[i].empty_att_set) {
								$('#sc_attSet thead tr').first().find('td').addClass("sc_invalid_filed");
							}
							if (data.Errors[i].fill_passport_data) {
								$('.zcontract-tab-url:contains("Паспортные данные")').parent().addClass("sc_invalid_filed")
							}
							if (data.Errors[i].fill_attcategories_data) {
								$('.zcontract-tab-url:contains("Категории доверенностей")').parent().addClass("sc_invalid_filed")
							}
							if(data.Errors[i].deal_type){
								$('#sc_partnerSet .sc_partnerSetRowDealType').addClass("sc_invalid_filed");
							}
							if(data.Errors[i].internal_partner){
								$('#sc_partnerSet .sc_partnerSetRowAffiliation').addClass("sc_invalid_filed");
							}
							if(data.Errors[i].type_cost){
								if($('#type_of_cost_attr').parent('td')[0]){
									$('#type_of_cost_attr').parent('td').prev().addClass("sc_invalid_filed");
									$('#type_of_cost_attr').parent('td').addClass("sc_invalid_filed");
								}
							}
							if(data.Errors[i].not_affil_partner){
								$('.sc_partnerSetRowID[value=' + data.Errors[i].not_affil_partner + ']').parent('td').addClass("sc_invalid_filed");
							}
						}
					}
					if (data.InvalidAttrs && data.InvalidAttrs.length){
						retMsg += 'Измените значения, подсвеченные красным\r';
						for (var i = 0; i < data.InvalidAttrs.length; i++) {
							var attr = data.InvalidAttrs[i];
							for (var j = 0; j < attr.invalid.length; j++) {
								$("[name=scAttr" + attr.CatID + "_1_" + attr.SetID + "_" + attr.AttrID + '_' + attr.invalid[j] + ']').addClass("sc_invalid");
							}
						}
					}
					if (data.question && data.questionMessage.length)
					{
						question = retMsg.length == 0;
						retMsg += data.questionMessage;
					}
					if (callback){
						callback(retMsg, question);
					}
				})
				.fail(function (error){
					callback("Server error: zdoc.CheckRequiredFields", false);
				});
			})
			.fail(function (error){
				callback("Server error: zdoc.CheckNotActing", false);
			});
		},
