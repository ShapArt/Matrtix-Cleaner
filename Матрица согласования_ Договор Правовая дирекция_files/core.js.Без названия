		initDependFields: function (depFields){
			for (var i = 0; i < depFields.length; i++){
				var field = depFields[i].field;
				field.depends = depFields[i].depends;
				$(field).change(function (event){

					if (!this.value){
						$(this.depends).val('');
					}
				})
			}
		}
