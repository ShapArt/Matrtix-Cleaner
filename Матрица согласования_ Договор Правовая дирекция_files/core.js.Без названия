		getPartners: function (nodeID, callback){
			$.getJSON(sc.urlPrefix, {'func': 'zdoc.GetContractPartners', 'objID': nodeID}, function (data){
				if (data.status != 'success' || data.partners == undefined){
					return alert('Error while getting partners data');
				}
				var partners = [];

				for (var i = 0; i < data.partners.length; i++){

					var partner = {};
					partner.id = data.partners[i].DataID || '';
					partner.num = data.partners[i].id || '';
					partner.name = data.partners[i].name || '';
					partner.affiliation = data.partners[i].affiliation || '';
					partner.inn = data.partners[i].partner_inn || '';
					partner.opf = data.partners[i].opf || '';
					partner.resident = data.partners[i].resident || '';
					partner.status = data.partners[i].partner_status || '';
					partner.status_date = data.partners[i].status_date || '';
					partner.op = data.partners[i].partner_op || '';
					partner.dealType = data.partners[i].partner_deal_type || '';

					partners.push(partner);
				}

				if (callback){
					return callback(partners);
				}else{
					return partners;
				}
			})
		},
		getAttornies: function (nodeID, callback){
			$.getJSON(sc.urlPrefix, {'func': 'zdoc.GetAttorneyAttornies', 'docID': nodeID}, function (data){
				if (data.status != 'success' || data.attornies == undefined){
					return alert('Error while getting attornies data');
				}
				var attornies = [];

				for (var i = 0; i < data.attornies.length; i++){

					var attorney = {};
					attorney.att_type = data.attornies[i].att_type;
					attorney.att_id = data.attornies[i].att_id;
					attorney.att_last_name = data.attornies[i].att_last_name || '';
					attorney.att_first_name = data.attornies[i].att_first_name || '';
					attorney.att_middle_name = data.attornies[i].att_middle_name || '';
					attorney.att_job_title = data.attornies[i].att_job_title || '';
					attorney.att_org_name = data.attornies[i].att_org_name || '';
					attorney.att_org_oco = data.attornies[i].att_org_oco;

					attornies.push(attorney);
				}

				if (callback){
					return callback(attornies);
				}else{
					return attornies;
				}
			})
		}		
