var sc_ModelUser = {
	items: [],

	getUserByID: function (id, returnIdx){
		for (var i = 0; i < this.items.length; i++){
			if (this.items[i].id == id){
				return (returnIdx) ? i : this.items[i];
			}

		}

		//If doest find anyting
		return {id: -1, title: '!Error, user not found'}
	},

	populateFromArray: function (userIdArray){
		var result = [];

		for (var i = 0; i < userIdArray.length; i++){
			result.push(this.getUserByID(userIdArray[i]));
		}
		return result;
	},

	getBySearch: function (searchString, matchCase, returnIdx){
		if (!matchCase){
			searchString = searchString.toLowerCase();
		}

		for (var i = 0; i < this.items.length; i++){
			if (this.items[i].title.indexOf(searchString))
				return (returnIdx) ? i : this.items[i];
			}

		//If doest find anyting
		return {id: -1, title: '!Error, user not found'}
	}
};

