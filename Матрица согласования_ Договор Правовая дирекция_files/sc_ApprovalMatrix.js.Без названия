	checkEDS: function(){
		var signColIdx;
		var colInfo;

		for (var colIdx = 0; colIdx < this.cols.length; colIdx++){
			colInfo = this.getColInfo(colIdx);
			if(colInfo.colType=='level' && colInfo.type=='signing'){
				signColIdx=colIdx;
				break;
			}
		}

		if(!signColIdx){
			return true;
		}

		var item
		var rowList='';

		for (var rowIdx = 0; rowIdx < this.items.length; rowIdx++){
			item=this.items[rowIdx][colIdx];
			if(item.performerList && item.performerList.length>1){
				if (rowList.length>0){
					rowList+=',';
				}
				rowList+=this.mRecsID[rowIdx];
			}
		}
		if (rowList.length>0){
			alert('В строках матрицы ' + rowList + ' указано более одного значения. Пожалуйста, внесите изменения, после чего выполните сохранение изменений.');
			return false;
		}

		rowList=''
		for (var rowIdx = 0; rowIdx < this.items.length; rowIdx++){
			item=this.items[rowIdx][colIdx];
			if(item.performerList>0 && !item.edsDocTypeCode){
				if (rowList.length>0){
					rowList+=',';
				}
				rowList+=this.mRecsID[rowIdx];
			}
		}
		if (rowList.length>0){
			alert('В строках матрицы ' + rowList + ' выбраны исполнители для шага Подписание, но не выбран ключ типа документа в колонке ЭП. Пожалуйста, внесите изменения, после чего выполните сохранение изменений.');
			return false;
		}
		
		return true;
	},
	
