								}
							}
						}
						if (found) {
							$(".changeAvailable").each(function() {
								var $a = $(this).find("a");
								$a.each(function() {
									if ($(this).html() == $("#currentApprover").next().val().replace(/\"/g, "") + sc_ApprovalMatrix.multipleAttributesDelimiter) {
										$(this).attr("userid", $("#newApprover").val());
										$(this).html($("#newApprover").next().val().replace(/\"/g, "") + sc_ApprovalMatrix.multipleAttributesDelimiter);
										$(this).attr("href", $(this).attr("href").replace($("#currentApprover").val(), $("#newApprover").val()));
									}
								});
							});
						}
						$("#currentApprover").val("");
						$("#newApprover").val("");
						$("#currentApprover").next().removeClass("sc_invalid").val("");
						$("#newApprover").next().removeClass("sc_invalid").val("");
						if (!confirm("Замена согласующих выполнена успешно. Продолжить работу с формой?")) {
							$(this).dialog("close");
						}
					}
				},
				"Отмена": function (){
					$("#currentApprover").val("");
					$("#newApprover").val("");
					$("#currentApprover").next().removeClass("sc_invalid").val("");
					$("#newApprover").next().removeClass("sc_invalid").val("");
					$(this).dialog('close');
				}
			}
		});
	},

