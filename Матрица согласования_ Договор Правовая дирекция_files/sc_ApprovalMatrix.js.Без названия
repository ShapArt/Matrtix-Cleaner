					var result = [];
					$(this).find('input:checkbox').each(function (idx, el){
						result.push(el.value);
					});
					sc.processDFCbuttons(colInfo, result, functions, itemIdx);
					$target.html(result.join(sc.multipleAttributesDelimiter + '<br />')).append($('<input type="hidden" />').val(result.join(sc.multipleAttributesDelimiter)));
					$div.dialog("destroy");
				},
				"Выбрать": function (){
					var result = [];
					$(this).find('input:checked').each(function (idx, el){
						result.push(el.value);
					});
					sc.processDFCbuttons(colInfo, result, functions, itemIdx);
					$target.html(result.join(sc.multipleAttributesDelimiter + '<br />')).append($('<input type="hidden" />').val(result.join(sc.multipleAttributesDelimiter)));
					$(this).dialog("destroy");
				},
				"Очистить": function (){
					$(this).find('input:checked').each(function (idx, el){
						$(this).prop("checked", false);
					});
				}
			}
		});

		if (colInfo.validValues.length == 1 && ['direction', 'functions', 'category'].indexOf(colInfo.alias) < 0) {
			$.post(sc.urlPrefix, {
					'func': 'zdoc.GetTableLookupDialog',
					'catID': colInfo.catID,
					'attrAlias': colInfo.alias,
					'partnerID': partnerID,
					'direction': direction,
					'functions': functions,
					'category':category,
				}, function (data){
					if (typeof data == 'string') {
						data = JSON.parse(data);
					}
					if (data.status != 'success'){
						return alert('Error while getting partner data');
					}

					sc_ApprovalMatrix.buildCheckboxForm($div, curCol, selectedItems, data.validList);
			});
		} else {
			sc_ApprovalMatrix.buildCheckboxForm($div, curCol, selectedItems, colInfo.validValues);
		}
