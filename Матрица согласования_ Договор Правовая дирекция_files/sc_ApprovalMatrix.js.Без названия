			}
		}

		//Replace old element state view width new state view
		var targetEl = element.prev();
		var newEl = this.renderItemView(parseInt(element.attr('itemID')), !element.hasClass('sc_editMode'));

		if (targetEl.length){
			targetEl.after(newEl);
		}else{
			//If we coundt get prev() element, we in the first element, prepend new state to tbody
			targetEl = element.parent();
			targetEl.prepend(newEl);
		}

		//Destroy tokenInput garbadge
		element.find('input.sc_user').each(function (idx, element){
			$(element).tokenInput('destroy');
		});
		//Remove old state view
		element.remove();
		this.hoverActionsShow(newEl);
	},

	saveItemDataFromView: function (element){
		var colInfo;
		var colField;
		var colsEl = element.find('td');
		var itemIdx = parseInt(element.attr('itemID'));
		var oldItem = this.items[itemIdx];
		var errArr = [];
		var errMsg = '';

		this.filterHide();
		//Going through each col
		for (var i = 0; i < this.cols.length; i++){
			colInfo = this.cols[i];

			if (colInfo.colType == 'attribute'){
				if (this.isAttributeBetweenType(i)){
					var firstVal = $.trim($(colsEl[i]).find('input').val());
					var secondVal = $.trim($(colsEl[i + 1]).find('input').val());
					var fFirstVal = parseFloat(firstVal);
					var fSecondVal = parseFloat(secondVal);

					if ((firstVal && firstVal != fFirstVal) || (secondVal && secondVal != fSecondVal)){
						errMsg = this.lang.inColumneNo.replace('#', colInfo.title) + this.lang.checkBetweenFields;
						errArr.push(errMsg);
					}

					//Between attr build in two columns
					this.items[itemIdx][i] = [
						isNaN(parseFloat(firstVal)) ? undefined : parseFloat(firstVal),
						isNaN(parseFloat(secondVal)) ? undefined : parseFloat(secondVal)
					];

					//Slice one for between field
					colsEl = colsEl.not(':eq(' + i + ')');
				} else if (this.isAttributePartnerType(i)){
					var firstVal = $.trim($(colsEl[i]).find('input').val());
					var strAsArray = firstVal.split(this.multipleAttributesDelimiter);
					var arrToSave = [];
					if (firstVal != "" && firstVal != "NaN" && firstVal != sc_ApprovalMatrix.nullValue) {
						var secondVal = $(colsEl[i + 1]).find('div').html();
						for (var j = 0; j < strAsArray.length; j++) {
							var newVal = parseInt(strAsArray[j]);
							if (secondVal == sc_ApprovalMatrix.conditions[1]) {
								arrToSave.push(newVal > 0 ? -newVal : newVal);
							} else {
								arrToSave.push(newVal < 0 ? -newVal : newVal);
							}
						}
					}
					this.items[itemIdx][i] = arrToSave;
					colsEl = colsEl.not(':eq(' + i + ')');
				}else if ((colField = $(colsEl[i]).find('textarea, input')).length){
					//Simple text field, or hidden input
					//Any data must save as array
					var strAsArray = colField.val().split(this.multipleAttributesDelimiter);
					var arrToSave = [];
					for (var j = 0; j < strAsArray.length; j++){
						if (strAsArray[j] && strAsArray[j] != this.nullValue){
							if (this.isAttributeIntType(i)){
								arrToSave.push(parseInt(strAsArray[j]));
							}else{
								arrToSave.push(strAsArray[j]);
							}
						}
					}
		
					this.items[itemIdx][i] = arrToSave;
				}else if ((colField = $(colsEl[i]).find('select')).length){
					//Popup field
					this.items[itemIdx][i] = colField.val() || [];
				}
			}else if (colInfo.colType == 'level' || colInfo.colType == 'function'){
				colField = $(colsEl[i]).find('.sc_user');
				var fieldTokens = colField.tokenInput('get');
				
				this.items[itemIdx][i].performerList = [];
				//We shoud save only id
				for (var j = 0; j < fieldTokens.length; j++){
					this.items[itemIdx][i].performerList.push(fieldTokens[j].id);
				}

				if (this.edsEnabled && colInfo.type=='signing'){
					var	eds=$('#colInputEDS' + colField.attr('zid'));

					this.items[itemIdx][i].edsDocTypeCode=eds.val();
				
					//Slice one for eds
					colsEl = colsEl.not(':eq(' + i + ')');
				}
			}else{
				this.onError({type: 'html', msg: 'Can\'t get column declaration, colID: (' + i + ')'})
			}
		}

		if (errArr.length){
			//If has some error, revent changes
			this.items[itemIdx] = oldItem;
			alert(errArr.join("\r"));
			return false;
		}else{
			this.itemsEdit.push(this.mRecsID[itemIdx]);
			this.isChangedItemsWasSave = false;
			return true;
		}
	},

	//Hover actions
	hoverActionsShow: function (targetElement){

		var targetPos = targetElement.position();
		var windowWidth = $(window).width() + $(window).scrollLeft();

		//Save link to target element
		this.hoverActions.targetEl = targetElement;

		//Toogle actions depend on target state
		if (targetElement.hasClass('sc_editMode')){
			this.hoverActions.actions.editEl.hide();
			this.hoverActions.actions.copyEl.hide();
			this.hoverActions.actions.deleteEl.hide();
			this.hoverActions.actions.newEl.hide();
			this.hoverActions.actions.saveEl.show();
			this.hoverActions.actions.rollback.show();
		}else{
			this.hoverActions.actions.saveEl.hide();
			this.hoverActions.actions.rollback.hide();
			this.hoverActions.actions.editEl.show();
			this.hoverActions.actions.copyEl.show();
			this.hoverActions.actions.newEl.show();
			this.hoverActions.actions.deleteEl.show();
		}

		//Align to the right border of screen
		this.hoverActions.el
			.css({
				top: targetPos.top,
				left: (windowWidth - 10 - this.hoverActions.el.outerWidth())
			})
			.show();
	},

	hoverActionsHide: function (){
		this.hoverActions.el.hide();
	},

	addRecord: function (appendAfterItem){
		var itemIdx = parseInt(appendAfterItem.attr('itemid'));

		if ($.type(itemIdx) == 'number'){
			++itemIdx;
			this.items.splice(itemIdx, 0, this.generateEmptyItem());
			var mRecID = 0;//NEW
			this.mRecsID.splice(itemIdx, 0, mRecID);//NEW
			this.mRecsStatus.splice(itemIdx, 0, 1);
			appendAfterItem.after(this.renderItemView(itemIdx, false));
			this.recalculateItems();
		}else{
			this.onError({type: 'itemIdx', msg: 'Could\'t get item id while deleting row'});
		}

		this.hoverActionsHide();
	},

	copyRecord: function (appendAfterItem){
		var itemIdx = parseInt(appendAfterItem.attr('itemid'));

		if ($.type(itemIdx) == 'number'){
			++itemIdx;
			this.items.splice(itemIdx, 0, this.copyItem(this.items[itemIdx-1]));
			var mRecID = 0;//NEW
			this.mRecsID.splice(itemIdx, 0, mRecID);//NEW
			this.mRecsStatus.splice(itemIdx, 0, 1);
			appendAfterItem.after(this.renderItemView(itemIdx, false));
			this.recalculateItems();
		}else{
			this.onError({type: 'itemIdx', msg: 'Could\'t get item id while deleting row'});
		}

		this.hoverActionsHide();
	},

	recalculateItems: function (){
		var elems = this.element.find('tbody > tr');
		if (elems.length == this.items.length){
			elems.each(function (idx, el){
				$(this).attr('itemid', idx);
			});
		}else{
			this.onError('Count of table rows != items count');
		}
	},

	deleteRecord: function (item){
		var itemIdx = parseInt(item.attr('itemid'));

		if ($.type(itemIdx) == 'number'){
			if (this.items.length == 1){
				//Cant delete last record
				this.onError({type: 'item', msg: 'Could\'t delete last row'});
				return false;
			}
			this.items.splice(itemIdx, 1);
			this.itemsDel.push(this.mRecsID[itemIdx]);
			this.mRecsID.splice(itemIdx, 1);//NEW
			item.remove();
			this.recalculateItems();
		}else{
			this.onError({type: 'itemIdx', msg: 'Could\'t get item id while deleting row'});
		}

		this.hoverActionsHide();
	},

	//Filter actions
	filterShow: function (element){
		//If already opened, just close it
		if (this.filter.el && this.filter.el.is(':visible')){
			return this.filterHide();
		}

		//Hide before showing, DOM manipulation got more perfomance, if element is hidden
		this.filterHide();

		//Get idx of element in item
		var itemColIdx = element.attr('itemColIdx');

		this.filter.lastItemCol = {idx: itemColIdx};

		//Clear values for filter
		this.filter.valuesList = [];

		//Temp function for push somethink in valuesList, if it is not exist already
		var pushValidValueIfNotExist = function (haystack, value){
			if ($.type(value) == 'object'){
				var found = false;
				for (var i = 0; i < haystack.valuesList.length; i++){
					var curItem = haystack.valuesList[i];
					if (curItem.id == value.id){
						found = true;
						break;
					}
				}
				if (!found){
					haystack.valuesList.push(value);
				}
			}else{
				if (value != null && haystack.valuesList.indexOf(value) === -1){
					haystack.valuesList.push(value);
				}
			}
		};

		if (this.cols[itemColIdx].colType == 'level' || this.cols[itemColIdx].colType == 'function'){
			if ($(event.target).hasClass('edsDocTypeCode')){
				this.filter.lastItemCol.addInfo = 'edsDocTypeCode';
			}else{
				this.filter.lastItemCol.addInfo = 'performerList';
			}
		}else if (this.isAttributeBetweenType(itemColIdx)){
			if ($(event.target).hasClass('from')){
				this.filter.lastItemCol.addInfo = 'from';
			}else{
				this.filter.lastItemCol.addInfo = 'to';
			}
		}else if (this.isAttributePartnerType(itemColIdx)){
			if ($(event.target).hasClass('condition')){
				this.filter.lastItemCol.addInfo = 'condition';
			}
		}


		//populate filter valid list
		//itar thru visible items
		pushValidValueIfNotExist(this.filter, this.nullValue);
		if (!$('#FilterOnlyMatrix').prop('checked') && this.filtrCol.has(+itemColIdx)){
			var valuesFilter = this.filtrCol.get(+itemColIdx)
			for (var i = 0; i < valuesFilter.length; i++){
				if (this.isAttributePartnerType(itemColIdx)){
					pushValidValueIfNotExist(
						this.filter,
						{
							id: (valuesFilter[i].DataID > 0 ? valuesFilter[i].DataID : -valuesFilter[i].DataID),
							title: valuesFilter[i].name
						}
					);	
				}else if (this.isAttributeClassificationType(+itemColIdx)){
					pushValidValueIfNotExist(this.filter, valuesFilter[i].Name);
				}else{
					pushValidValueIfNotExist(this.filter, valuesFilter[i]);
				}
			}
		}else{
			for (var i = 0; i < this.items.length; i++){

				//If element value is array
				if ($.type(this.items[i][itemColIdx]) == 'array' || $.type(this.items[i][itemColIdx]) == 'object'){
					//Betweeen type
					if (this.isAttributeBetweenType(itemColIdx)){

						//Check if has class from, take first element of array, if not, take second
						if ($(event.target).hasClass('from')){
							pushValidValueIfNotExist(this.filter, this.items[i][itemColIdx][0]);
						}else{
							pushValidValueIfNotExist(this.filter, this.items[i][itemColIdx][1]);
						}

					}else if (this.cols[itemColIdx].colType == 'level' || this.cols[itemColIdx].colType == 'function'){
						if ($(event.target).hasClass('edsDocTypeCode')){
							if (this.items[i][itemColIdx].edsDocTypeCode){
								for(var j=0; j<this.edsDocTypeCodes.length; j++){
									if (this.items[i][itemColIdx].edsDocTypeCode==this.edsDocTypeCodes[j].code){
										pushValidValueIfNotExist(
											this.filter, {
												id : this.edsDocTypeCodes[j].code,
												title : this.edsDocTypeCodes[j].title
											}
										);
									}
								}
							}
						}else{
							for (var j = 0; j < this.items[i][itemColIdx].performerList.length; j++){
								pushValidValueIfNotExist(
									this.filter,
									sc_ModelUser.getUserByID(
										this.items[i][itemColIdx].performerList[j]
									)
								);
							}
						}
					}else{
						//Any other array
						for (var j = 0; j < this.items[i][itemColIdx].length; j++){
							if (this.isAttributePartnerType(itemColIdx)){
								if ($(event.target).hasClass('condition')){
									pushValidValueIfNotExist(this.filter, sc_ApprovalMatrix.conditions[0]);
									pushValidValueIfNotExist(this.filter, sc_ApprovalMatrix.conditions[1]);
								} else {
									pushValidValueIfNotExist(
										this.filter,
										{
											id: (this.items[i][itemColIdx][j] > 0 ? this.items[i][itemColIdx][j] : -this.items[i][itemColIdx][j]),
											title: this.partnerCacheObject[(this.items[i][itemColIdx][j] > 0 ? this.items[i][itemColIdx][j] : -this.items[i][itemColIdx][j])]
										}
									);
								}
							}else{
								//Popup attribute, or text with delimiter inside
								pushValidValueIfNotExist(this.filter, this.items[i][itemColIdx][j]);
							}

						}
					}

				}else{
					//Text attribute without delimiter
					pushValidValueIfNotExist(this.filter, this.items[i][itemColIdx]);
				}

			}	
		}

		this.filterRender(element);
	},

	filterHide: function (){
		if (this.filter.el)
			this.filter.el.hide();
	},

	filterRender: function (parentEl){

		//If filter calling first time, shoud init template
		if (!this.filter.el){
			this.filter.el = $('<div class="sc_tableFilter" style="height: auto"></div>').css('display', 'none');
			this.filter.el.append($('<h3></h3>').text(this.lang.filterTitle));
			this.filter.el.append($('<br><input type="input" value="" id="sc_filterForFilterValues">'));
			this.filter.ul = $('<ul class="sc_filterPropsList"></ul>');
			//Select all checkbox, for selecting all other options in list by one click
			this.filter.ul.append(
				$('<li class="sc_selectAll"></li>').append(
					$('<label></label>').text(this.lang.selectAll).prepend(
						$('<input type="checkbox" value="">').click({context: this}, this.onFilterSelectAllClick)
					)
				)
			);
			this.filter.el.append(this.filter.ul);
			//Buttons in filter
			this.filter.el.append(
				$('<div class="sc_filterButton"></div>').append(
					$('<button type="button"></button>')
						.text(this.lang.apply)
						.click({context: this}, this.onFilterApplyClick),
					$('<button type="button"></button>')
						.text(this.lang.clear)
						.click({context: this}, this.onFilterClearClick)
				)
			);

			//if (sc_ApprovalMatrix.isEditable && this.filter.lastItemCol.addInfo && this.filter.lastItemCol.addInfo == 'performerList') {
			this.filter.el.append(
				$('<br>'));
			this.filter.el.append(
				$('<div class="sc_filterButton sc_CopyDataButtons"></div>').append(
					$('<button type="button" id="copyDataButton"></button>')
						.text(this.lang.copyColumnData)
						.click({context: this}, this.onFilterCopyDataClick),
					$('<button type="button" id="insertDataButton" ' + (sc_ApprovalMatrix.isDataCopied ? '' : 'disabled') + '></button>')
						.text(this.lang.insertColumnData)
						.click({context: this}, this.onFilterInsertDataClick)
				)
			);
			
			//Append to body, because of absolute position
			this.filter.el.appendTo('body');
		}
		//End template init

		var filterList = '';
		//Each value in filtr condition list
		var vals = [];
		if (this.filter.lastItemCol.addInfo && this.filter.lastItemCol.addInfo == "condition") {
			for (var i = 0; i < sc_ApprovalMatrix.conditions.length; i++) {
				filterList += '<li><label><input type="checkbox" value="' + sc_ApprovalMatrix.conditions[i] + '"';
				if (this.filter.colsFilterArray[this.filter.lastItemCol.idx] &&
					this.filter.colsFilterArray[this.filter.lastItemCol.idx].condition &&
					this.filter.colsFilterArray[this.filter.lastItemCol.idx].condition.indexOf(sc_ApprovalMatrix.conditions[i]) >= 0) {
						filterList += ' checked="checked"';
				}
				filterList += '>' + sc_ApprovalMatrix.conditions[i] + '</label></li>';
			}
		} else {
			for (var i = 0; i < this.filter.valuesList.length; i++){
				if ($.type(this.filter.valuesList[i]) == 'array'){
					var value = 'Тип = ' + (this.filter.valuesList[i][0][0] || '*') + ', ВН = ' + (this.filter.valuesList[i][1][0] || '*') + ';'
					if (vals.indexOf(value) != -1) {
						continue;
					}
					vals.push(value);
					filterList += '<li><label><input type="checkbox"'
						+ (
							(this.filter.colsFilterArray[this.filter.lastItemCol.idx]
								&& this.filter.colsFilterArray[this.filter.lastItemCol.idx]
								.indexOf(value) != -1)
							? ' checked="checked"'
							: ''
						)
						+ ' value="' + value + '">'
						+ value
						+ '</label></li>';
				} else if ($.type(this.filter.valuesList[i]) == 'object'){
					//Complex objects like users
					if (this.filter.lastItemCol.addInfo){
						filterList += '<li><label><input type="checkbox"'
							+ (
								((this.filter.colsFilterArray[this.filter.lastItemCol.idx][this.filter.lastItemCol.addInfo]
										.indexOf(this.filter.valuesList[i].id) != -1) 
									|| (isNaN(this.filter.colsFilterArray[this.filter.lastItemCol.idx][this.filter.lastItemCol.addInfo]) 
									&& this.filter.valuesList[i].id == this.nullValue))
								? ' checked="checked"'
								: ''
							)
							+ ' value="' + this.filter.valuesList[i].id + '">'
							+ this.filter.valuesList[i].title
							+ '</label></li>';
					}else{
						filterList += '<li><label><input type="checkbox"'
							+ (
								(this.filter.colsFilterArray[this.filter.lastItemCol.idx]
									&& this.filter.colsFilterArray[this.filter.lastItemCol.idx]
									.indexOf('' + this.filter.valuesList[i].id) != -1)
								? ' checked="checked"'
								: ''
							)
							+ ' value="' + this.filter.valuesList[i].id + '">'
							+ this.filter.valuesList[i].title
							+ '</label></li>';
					}
				}else{
				//Simple objects
					if (this.filter.lastItemCol.addInfo){
						//Between attribute, shoud send direction as addInfo property ("from", "to")

						filterList += '<li><label><input type="checkbox"'
							+ (
								((this.filter.colsFilterArray[this.filter.lastItemCol.idx][this.filter.lastItemCol.addInfo]
										.indexOf(this.filter.valuesList[i]) != -1) 
									|| (this.filter.colsFilterArray[this.filter.lastItemCol.idx][this.filter.lastItemCol.addInfo]
											.indexOf(this.nullValue)!= -1 
										&& this.filter.valuesList[i] == this.nullValue))
								? ' checked="checked"'
								: ''
							)
							+ ' value="' + ($.type(this.filter.valuesList[i]) == 'string' ? this.filter.valuesList[i].replace(/"/g, '&quot;') : this.filter.valuesList[i]) + '">'
							+ this.filter.valuesList[i]
							+ '</label></li>';
					}else{
						//Default attribute
						filterList += '<li><label><input type="checkbox"'
							+ (
								(this.filter.colsFilterArray[this.filter.lastItemCol.idx]
									.indexOf(this.filter.valuesList[i]) != -1)
								? ' checked="checked"'
								: ''
							)
							+ ' value="' + ($.type(this.filter.valuesList[i]) == 'string' ? this.filter.valuesList[i].replace(/"/g, '&quot;') : this.filter.valuesList[i]) + '">'
							+ this.filter.valuesList[i]
							+ '</label></li>';
					}
				}
			}
		}

		$("#sc_filterForFilterValues").val("");
		$("#sc_filterForFilterValues").on("change paste keyup", function() {
			var $fltr = $("#sc_filterForFilterValues");
			for (var i = 1; i < $(".sc_filterPropsList").find("li").length; i++) {
				var $li = $($(".sc_filterPropsList").find("li")[i]);
				if ($li.text().toLowerCase().indexOf($fltr.val().toLowerCase()) >= 0) {
					$li.show();
				} else {
					$li.hide();
				}
			}
		});
		//Delete all exist conditions except select_All checkbox, as its first element
		this.filter.ul.find('li:not(:eq(0))').remove();
		//Append new conditions
		this.filter.ul.append(filterList);

		//check if selectAll shoud be checked or not, exclude selectAll is first element
		var inputs = this.filter.ul.find('input').not(':eq(0)');
		//inputs.eq(0).prev() is are selectAll checkbox. If checked count == count of  all inputs
		inputs.eq(0).prev().prop('checked', (inputs.length == inputs.filter(':checked').length));

		//Column element where filterShow was called
		this.filter.lastItemCol.el = parentEl;
		//Positioning
		var parentPos = $(parentEl).position();
		parentPos.top += $(parentEl).outerHeight();
		parentPos.left += $(parentEl).outerWidth() - 15;
		//If element is positioning out of documents bounds
		if (this.filter.el.outerWidth() + parentPos.left >= $(document).width()){
			parentPos.left -= this.filter.el.outerWidth() - 15;
		}
		this.filter.el.css({'top': parentPos.top, 'left': parentPos.left}).show();
		$(".sc_tableFilter").height($(".sc_filterPropsList").height() + (sc_ApprovalMatrix.isEditable && this.filter.lastItemCol.addInfo && this.filter.lastItemCol.addInfo == 'performerList' ? 150 : 120));
		$(".sc_tableFilter").resizable({
			minWidth: 283,
			minHeight: $(".sc_filterPropsList").height() + (sc_ApprovalMatrix.isEditable && this.filter.lastItemCol.addInfo && this.filter.lastItemCol.addInfo == 'performerList' ? 150 : 120)
		});

		if (sc_ApprovalMatrix.isEditable && this.filter.lastItemCol.addInfo && this.filter.lastItemCol.addInfo == 'performerList' && this.cols[this.filter.lastItemCol.idx].title != 'ЭП') {
			$('.sc_CopyDataButtons').show();
			var isEnableCopyButton = false;
			for (var i = 0; i < this.items.length; i++) {
				if (this.items[i][this.filter.lastItemCol.idx].performerList.length > 0) {
					isEnableCopyButton = true;
					break;
				}
			}
			if (isEnableCopyButton) {
				$('#copyDataButton').prop('disabled', false);
			} else {
				$('#copyDataButton').prop('disabled', true);
			}
		} else {
			$('.sc_CopyDataButtons').hide();
		}

		if (sc_ApprovalMatrix.isDataCopied) {
			$('#insertDataButton').prop('disabled', false);
		} else {
			$('#insertDataButton').prop('disabled', true);
		}
	},

	filterApply: function (){
		var conditionWasChecked = false;

		//Clear condition in current item property
		if (this.filter.lastItemCol.addInfo){
			//If complex condition, e.g. between type
			this.filter.colsFilterArray[this.filter.lastItemCol.idx][this.filter.lastItemCol.addInfo] = [];
		}else{
			//Simple condition
			if(this.filter.lastItemCol.idx == 0){
				this.filter.colsFilterArray[this.filter.lastItemCol.idx].length = 0;
			}else{
				this.filter.colsFilterArray[this.filter.lastItemCol.idx] = [];
			}
		}

		var context = this;
		//Each checked condition
		this.filter.ul.find('input:checked').each(function (){
			if (this.value){
				//If this is an object, its are complex condition
				if (context.filter.lastItemCol.addInfo){
					if (parseFloat(this.value)){
						context.filter
							.colsFilterArray[context.filter.lastItemCol.idx][context.filter.lastItemCol.addInfo]
							.push(parseFloat(this.value));
					}else{
						context.filter
							.colsFilterArray[context.filter.lastItemCol.idx][context.filter.lastItemCol.addInfo]
							.push(this.value);
					}
				}else{
					//Simple condition
					context.filter.colsFilterArray[context.filter.lastItemCol.idx].push(this.value);
				}
				//Check that some condition was selected
				conditionWasChecked = true;
			}
		});

		//toggle column class, for display is any condition is apply on this column
		this.filter.lastItemCol.el.toggleClass('sc_filterHasCondition', conditionWasChecked);

		this.filterItems();
	},

	filterItems: function (){
		var colInfo;

		//Clear this before start
		this.visibleItems = [];

		//Going through each visible item
		for (var itemIdx = 0; itemIdx < this.items.length; itemIdx++){
			var isItemSatisfiesCondition = true;
			//Each column(rule)
			for (var column = 0; column < this.filter.colsFilterArray.length; column++){
				var found = false;

				colInfo=this.getColInfo(column);

				if (this.isAttributePartnerType(column) && this.filter.colsFilterArray[column] && this.filter.colsFilterArray[column].condition){
					var isFound = false;
					if (this.filter.colsFilterArray[column].condition.length == 0) {
						isFound = true;
					}
					for (var i = 0; i < this.filter.colsFilterArray[column].condition.length; i++) {
						if (this.filter.colsFilterArray[column].condition[i] == sc_ApprovalMatrix.conditions[0] && (this.items[itemIdx][column].length == 0 || this.items[itemIdx][column].length > 0 && this.items[itemIdx][column][0] > 0)) {
							isFound = true;
						}
						if (this.filter.colsFilterArray[column].condition[i] == sc_ApprovalMatrix.conditions[1] && this.items[itemIdx][column].length > 0 && this.items[itemIdx][column][0] < 0) {
							isFound = true;
						}
					}
					//
					if(isFound){
						//If column rule is empty, dont check it
						if (this.filter.colsFilterArray[column].length == 0){
							//continue;
							found = true;
						}


						//Each value in column
						for (var conditionValue = 0; conditionValue < this.filter.colsFilterArray[column].length; conditionValue++){
							if (this.items[itemIdx][column].length == 0 && this.filter.colsFilterArray[column][conditionValue] == this.nullValue){
								found = true;
							}
							else{
								for (var idxOf = 0; idxOf < this.items[itemIdx][column].length; idxOf++){
									if(this.items[itemIdx][column][idxOf] == this.filter.colsFilterArray[column][conditionValue]){
										//We found one of possible variant, break this loop
										found = true;
										break;
									} else if ((colInfo.alias == 'partner_id' || colInfo.alias == 'partners_member_id' || colInfo.alias == 'partners_internal_id') && (this.items[itemIdx][column][idxOf] == -this.filter.colsFilterArray[column][conditionValue])) {
										found = true;
										break;
									}
								}
							}
							//Dont use indexOf here, because indexOf is strict search, and 1000 != "1000", but in our conditions 1000 == "1000" so strict mode is unnecessary
							//if (this.items[itemIdx][column].indexOf(this.filter.colsFilterArray[column][conditionValue]) != -1){
						}
					}
					//
				} else if (colInfo.id == -2){
					if (this.filter.colsFilterArray[column].length == 0) {
						found = true;
					} else {
						var value = "";
						if ($.type(this.items[itemIdx][column]) == 'array' && this.items[itemIdx][column].length > 0) {
							for (var i = 0; i < this.items[itemIdx][column].length; i++) {
								value += 'Тип = ' + (this.items[itemIdx][column][i][0][0] || '*') + ', ВН = ' + (this.items[itemIdx][column][i][1][0] || '*') + ';'
							}
						} else {
							value = this.nullValue;
						}
						for (var conditionValue = 0; conditionValue < this.filter.colsFilterArray[column].length; conditionValue++){
							var fvalue = this.filter.colsFilterArray[column][conditionValue];
							if (value.indexOf(fvalue) != -1){
								found = true;
								break;
							}
						}
					}
				}else if ($.type(this.filter.colsFilterArray[column]) == 'object'){
					//Beetween type
					if (this.isAttributeBetweenType(column)){
						var fromCondition = false,
							toCondition = false;

						//From
						if (this.filter.colsFilterArray[column].from.length == 0){
							fromCondition = true;
						}
						//Each value in column
						for (var conditionValue = 0; conditionValue < this.filter.colsFilterArray[column].from.length; conditionValue++){
							if ((this.items[itemIdx][column].length == 0 || !this.items[itemIdx][column][0]) && this.filter.colsFilterArray[column].from[conditionValue] == this.nullValue){
								fromCondition = true;
							} else {
								if(this.items[itemIdx][column][0] == this.filter.colsFilterArray[column].from[conditionValue]){
									fromCondition = true;
								}
							}
						}
						
						//To
						if (this.filter.colsFilterArray[column].to.length == 0){
							toCondition = true;
						}
						//Each value in column
						for (var conditionValue = 0; conditionValue < this.filter.colsFilterArray[column].to.length; conditionValue++){
							if ((this.items[itemIdx][column].length == 0 || !this.items[itemIdx][column][1]) && this.filter.colsFilterArray[column].to[conditionValue] == this.nullValue){
								toCondition = true;
							} else {
								if(this.items[itemIdx][column][1] == this.filter.colsFilterArray[column].to[conditionValue]){
									toCondition = true;
								}
							}
						}
						
						found = (fromCondition && toCondition);
					}else if(colInfo.colType=='level' || colInfo.colType=='function'){
						var perfCondition=false,
							edsCondition=false;

						if (this.filter.colsFilterArray[column].performerList.length){
							for (var conditionValue = 0; conditionValue < this.filter.colsFilterArray[column].performerList.length; conditionValue++){
								if (this.items[itemIdx][column].performerList.length == 0 && this.filter.colsFilterArray[column].performerList[conditionValue] == this.nullValue){
									perfCondition = true;
								}else{
									for (var idxOf = 0; idxOf < this.items[itemIdx][column].performerList.length; idxOf++){
										if(this.items[itemIdx][column].performerList[idxOf] == this.filter.colsFilterArray[column].performerList[conditionValue]){
											perfCondition = true;
											break;
										}
									}
								}
			
								if(perfCondition){
									break;
								}
							}
						}else{
							perfCondition=true;
						}

						if (this.filter.colsFilterArray[column].edsDocTypeCode.length){
							for (var conditionValue = 0; conditionValue < this.filter.colsFilterArray[column].edsDocTypeCode.length; conditionValue++){
								if (!this.items[itemIdx][column].edsDocTypeCode && this.filter.colsFilterArray[column].edsDocTypeCode[conditionValue] == this.nullValue){
									edsCondition = true;
									break;
								}else if(this.items[itemIdx][column].edsDocTypeCode == this.filter.colsFilterArray[column].edsDocTypeCode[conditionValue]){
									edsCondition = true;
									break;
								}
							}
						}else{
							edsCondition=true;
						}
					
						found = (perfCondition && edsCondition);
					}
				}else{
					//If column rule is empty, dont check it
					if (this.filter.colsFilterArray[column].length == 0){
						continue;
					}


					//Each value in column
					for (var conditionValue = 0; conditionValue < this.filter.colsFilterArray[column].length; conditionValue++){
						if (this.items[itemIdx][column].length == 0 && this.filter.colsFilterArray[column][conditionValue] == this.nullValue){
							found = true;
						}
						else{
							for (var idxOf = 0; idxOf < this.items[itemIdx][column].length; idxOf++){
								if(this.items[itemIdx][column][idxOf] == this.filter.colsFilterArray[column][conditionValue]){
									//We found one of possible variant, break this loop
									found = true;
									break;
								} else if ((colInfo.alias == 'partner_id' || colInfo.alias == 'partners_member_id' || colInfo.alias == 'partners_internal_id') && (this.items[itemIdx][column][idxOf] == -this.filter.colsFilterArray[column][conditionValue])) {
									found = true;
									break;
								}
							}
						}
						//Dont use indexOf here, because indexOf is strict search, and 1000 != "1000", but in our conditions 1000 == "1000" so strict mode is unnecessary
						//if (this.items[itemIdx][column].indexOf(this.filter.colsFilterArray[column][conditionValue]) != -1){
					}
				}      

				//Nothing is found, exit loop
				if (!found){
					isItemSatisfiesCondition = false;
					break;
				}
			}

			if (isItemSatisfiesCondition){
				//Nothing is found, hide this item
				this.visibleItems.push(itemIdx);
			}
		}

		if (this.visibleItems.length > 0 && this.isUserFiter){
			var newvisibleItems = [];
			var i;
			for (i = 0; i < this.userFilter.length; i++){
				if (this.visibleItems.indexOf(this.userFilter[i]) != -1){
					newvisibleItems.push(this.userFilter[i]);
				}
			}
			this.visibleItems = newvisibleItems;
		}
		
		//Just for next each
		var context = this;

		//Toogle elemenets to show that is satisfies condition, another must be hidden
		this.element.find('tbody > tr').each(function (idx, el){
			if (context.visibleItems.indexOf(idx) != -1){
				$(el).show();
			}else{
				$(el).hide();
			}
		});
	},

