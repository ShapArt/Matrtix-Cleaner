	//Render functions
	renderTable: function (element){

		this.element = $(element);

		//Count how many cells contains attributes, need only for view, maybe its not so important, and can be deleted;
		var attributeCells = 0;
		//See line up, but for levels and functions
		var stepsCells = 0;
		//index of property in items of currentCol
		var itemColIdx = 0;

		//Ofcourse init if didt do it before
		if (!this.initiated)
			this.init();

		//HoverActions  its actions when user hover on item view(TR), e.g. save, edit
		this.hoverActions.el = $('<div class="sc_hoverActions" style="display: none;"></div>');

		//Hover actions
		var hoverActionEditSaveAction = function (event){
			//Dont save new state
			event.data.context.toggleItemRenderState(event.data.context.hoverActions.targetEl, event.data.rollback);
			event.preventDefault();
		};
		var hoverActionNewAction = function (event){
			event.data.context.addRecord(event.data.context.hoverActions.targetEl);
			event.preventDefault();
		};
		var hoverActionDeleteAction = function (event){
			event.data.context.deleteRecord(event.data.context.hoverActions.targetEl);
			event.preventDefault();
		};
		var hoverActionCopyAction = function (event){
			event.data.context.copyRecord(event.data.context.hoverActions.targetEl);
			event.preventDefault();
		};

		this.hoverActions.actions.editEl =
			$('<a class="sc_hoverAction edit" href="#" title="' + this.lang.edit + '">'
				+ '<img border="0" src="' + this.supportPrefix + 'casebasic/edit.gif" /></a>')
					.click({context: this}, hoverActionEditSaveAction);
		this.hoverActions.actions.saveEl =
			$('<a class="sc_hoverAction save" href="#" title="' + this.lang.save + '">' +
				'<img border="0" src="' + this.supportPrefix + 'zdocs/apply.gif" /></a>')
					.click({context: this}, hoverActionEditSaveAction);
		this.hoverActions.actions.rollback =
			$('<a class="sc_hoverAction rollback" href="#" title="' + this.lang.cancel + '">' +
				'<img border="0" src="' + this.supportPrefix + 'zdocs/arrowleft.gif" /></a>')
					.click({context: this, rollback: true}, hoverActionEditSaveAction);
		this.hoverActions.actions.newEl =
			$('<a class="sc_hoverAction new" href="#" title="' + this.lang.new + '">' +
				'<img border="0" src="' + this.supportPrefix + 'add-row.gif" /></a>')
					.click({context: this}, hoverActionNewAction);
		this.hoverActions.actions.deleteEl =
			$('<a class="sc_hoverAction delete" href="#" title="' + this.lang.delete + '">' +
				'<img border="0" src="' + this.supportPrefix + 'delete-row.gif" /></a>')
					.click({context: this}, hoverActionDeleteAction);
		this.hoverActions.actions.copyEl =
			$('<a class="sc_hoverAction copy" href="#" title="' + this.lang.copy + '">' +
				'<img border="0" src="' + this.supportPrefix + 'copy-row.png" /></a>')
					.click({context: this}, hoverActionCopyAction);
		this.hoverActions.el
			.append(
				this.hoverActions.actions.newEl,
				this.hoverActions.actions.copyEl,
				this.hoverActions.actions.editEl,
				this.hoverActions.actions.saveEl,
				this.hoverActions.actions.rollback,
				this.hoverActions.actions.deleteEl
			)
			.appendTo('body');

		//THEAD start
		var theadItemsFirstLine = $('<tr></tr>');
		var theadItemsSecondLine = $('<tr></tr>');
		//Filters action
		theadItemsFirstLine.click({context: this}, this.onTableHeadClick);
		theadItemsSecondLine.click({context: this}, this.onTableHeadClick);


		//Render thead cols, in two lines.
		//First line contains attributes title, and levels;
		//Second line contains additional attributes properties, like between attribute, and functions of levels
		for (var attrIdx = 0; attrIdx < this.attributes.length; attrIdx++){
			//If attribute type is int, then we should use two columns, for between value
			if (this.isAttributeBetweenType(attrIdx)){
				theadItemsFirstLine.append('<td colspan="2" class="sc_THeadInfoTD">' + this.attributes[attrIdx].title + '</td>');
				//.sc_filter, class for excel like filter actions
				theadItemsSecondLine.append('<td class="sc_filter from" itemColIdx="' + itemColIdx + '">'
					+ this.lang.from
					+ '</td><td class="sc_filter to" itemColIdx="' + itemColIdx + '">'
					+ this.lang.to + '</td>');
				//So as between is two columns property...
				attributeCells += 2;
			}else if (this.isAttributePartnerType(attrIdx)){
				theadItemsFirstLine.append('<td colspan="2" class="sc_THeadInfoTD">' + this.attributes[attrIdx].title + '</td>');
				theadItemsSecondLine.append('<td class="sc_filter partner" itemColIdx="' + itemColIdx + '">'
					+ '</td><td class="sc_filter condition" itemColIdx="' + itemColIdx + '"></td>');
				attributeCells += 2;
			}else{
				//Regular attribute
				theadItemsFirstLine.append('<td rowspan="2" class="sc_filter" itemColIdx="' + itemColIdx + '">' + this.attributes[attrIdx].title + '</td>');
				++attributeCells;
			}
			//Shift idx to next item
			++itemColIdx;
		}

		//Going through each levels
		for (var levelIdx = 0; levelIdx < this.levels.length; levelIdx++){
			//If level got any functions, render it
			if (this.levels[levelIdx].functions.length){
				if (this.levels[levelIdx].functions.length == 1 && this.levels[levelIdx].title == this.levels[levelIdx].functions[0].title){
					//Simple level with one function and with same name, render it like level without function
					theadItemsFirstLine.append('<td rowspan="2" class="sc_filter" itemColIdx="' + itemColIdx + '">' + this.levels[levelIdx].title + '</td>');
					++stepsCells;
					++itemColIdx;
				}else{
					theadItemsFirstLine.append('<td class="sc_THeadInfoTD" colspan="' + this.levels[levelIdx].functions.length + '">' + this.levels[levelIdx].title + '</td>');
					//Each function render in secondTheadTr
					for (var a = 0; a < this.levels[levelIdx].functions.length; a++){
						theadItemsSecondLine.append('<td class="sc_filter" itemColIdx="' + itemColIdx + '">' + this.levels[levelIdx].functions[a].title + '</td>');
						//counting steps
						++stepsCells;
						//shift to next property
						++itemColIdx;
					}
				}
			}else{
				//If this levels without any function
				theadItemsFirstLine.append('<td rowspan="2" class="sc_filter" itemColIdx="' + itemColIdx + '">' + this.levels[levelIdx].title + '</td>');
				++stepsCells;
				++itemColIdx;
			}

			if (this.edsEnabled && this.levels[levelIdx].type=='signing'){
				theadItemsFirstLine.append('<td rowspan="2" class="sc_filter edsDocTypeCode" itemColIdx="' + (itemColIdx - 1) + '">' + this.lang.edsTitle + '</td>');
			}

		}

		theadItemsFirstLine.append('<td rowspan="2" class="sc_THeadInfoTD" > Номер строки </td>');
		var stepsCells2 = stepsCells+1;

		$('<thead></thead>')
			.append('<tr>' +
				'<td class="sc_THeadInfoTD" colspan="' + attributeCells + '">' + this.lang.keyFieldsTitle + '</td>' +
				'<td class="sc_THeadInfoTD" colspan="' + stepsCells2 + '">' + this.lang.levelAndFunctionsTitle + '</td>' +
				'</tr>')
			.append(theadItemsFirstLine)
			.append(theadItemsSecondLine).appendTo(this.element);

		//THEAD END

		//Render items
		var tbodyItems = $('<tbody></tbody>');

		//If no items in stock, add one empty
		if (this.items.length == 0){
			this.items.push(this.generateEmptyItem());
		}

		for (var itemIdx = 0; itemIdx < this.items.length; itemIdx++){
			tbodyItems.append(this.renderItemView(itemIdx));

		}

		//Render whole table
		tbodyItems.appendTo(this.element);
		
		for (var i = 0; i < this.cols.length; i++){
			if (this.cols[i].colType != 'attribute'){
				continue;
			}
			if (this.cols[i].alias == 'partner_id'){
				 this.elementsFiltr.set('partner_id', i);
					$.getJSON(sc.urlPrefix, {
							'func': 'zdoc.GetPartnerSet',
						}, function (data){
							if (data.status != 'success'){
								return alert('Error while getting partner data');
							}
							sc_ApprovalMatrix.filtrCol.set(sc_ApprovalMatrix.elementsFiltr.get('partner_id'), data.partnerSet);
						}
					);
			}
			else if (this.cols[i].alias == 'partners_internal_id'){
				 this.elementsFiltr.set('partners_internal_id', i);
					$.getJSON(sc.urlPrefix, {
							'func': 'zdoc.GetPartnerSet',
						}, function (data){
							if (data.status != 'success'){
								return alert('Error while getting partner data');
							}
							sc_ApprovalMatrix.filtrCol.set(sc_ApprovalMatrix.elementsFiltr.get('partners_internal_id'), data.partnerSet);
					}
				);
			}
			else if (this.isAttributeComplex(i)){
				 this.elementsFiltr.set('AttributeComplex', i);
				 $.getJSON(sc.urlPrefix, {
						'func': 'zdoc.GetComplexAttrVV',
						'recID': this.cols[i]
					}, function (data){
						if (data.status != 'success'){
							return alert('Error while getting partner data');
						}
						var elFilter = new Array();
						for (var i = 0; i < data.opts[0].length; i++)
						{
							for (var j = 0; j < data.opts[1].length; j++){
								elFilter.push(data.opts[0][i] + ',' + data.opts[1][j]);
							}
						}
						sc_ApprovalMatrix.filtrCol.set(sc_ApprovalMatrix.elementsFiltr.get('AttributeComplex'), elFilter);
					}
				);
			}
			else if (this.isAttributeTableLookupType(i)){
				this.elementsFiltr.set(this.cols[i].alias, i);
					$.getJSON(sc.urlPrefix, {
						'func': 'zdoc.GetTableLookupDialog',
						'catID': this.cols[i].catID,
						'attrAlias': this.cols[i].alias,
						'partnerID': 0
						}, function (data){
							if (data.status != 'success'){
								return alert('Error while getting partner data');
							}
							sc_ApprovalMatrix.filtrCol.set(sc_ApprovalMatrix.elementsFiltr.get(data.attrAlias), data.validList);
						}
					);				
			}
			else{
				if (this.cols[i].validValues)
				{
					this.filtrCol.set(i, this.cols[i].validValues);
				}
			}
		}

		$.getJSON(sc.urlPrefix, {
			'func': 'zdoc.GetDFC'
		}, function (data){
			if (!data.ok) {
				return alert('Error while getting partner data');
			}
			sc_ApprovalMatrix.dfc = data.dfc;
		});
	},

	renderItemView: function (itemIdx, editMode){
		var item = $('<tr></tr>').attr('itemID', itemIdx);

		if (editMode){
			item.addClass('sc_editMode');
		}else{
			item.removeClass('sc_editMode');
		}

		//Render each col in item
		var wasChanges = 0;
		for (var colIdx = 0; colIdx < this.items[itemIdx].length; colIdx++){
			var colElement = this.renderItemColView(itemIdx, colIdx, editMode);
			item.append(colElement);
			var arr = [];
			if ($.type(colElement) == 'array') {
				arr = colElement;
			} else {
				arr.push(colElement);
			}
			for (var i = 0; i < arr.length; i++) {
				if ($(arr[i]).hasClass("sc_showDeleteCel") || $(arr[i]).hasClass("sc_showAddCel") || $(arr[i]).hasClass("sc_showEditCel")) {
					wasChanges = 1;
				}
			}
		}
		if (wasChanges == 0) {
			$(item).addClass("nochanges");
		}

		var rowId;
		if (this.mRecsID[itemIdx] === undefined){
			rowId = 0;
		}else{
			rowId = this.mRecsID[itemIdx];
		}
		item.append('<td> '+ rowId +'</td>');//NEW
		
		//Events binding
		if (this.isItemsEditable()){
			item.mouseenter({context: this, action: 'enter'}, this.onTBodyTrHover)
				.mouseleave({context: this, action: 'leave'}, this.onTBodyTrHover);
		}

		return item;
	},

	row_direction: [],
	row_functions: [],
	row_category: [],
	
	renderItemColView: function (itemIdx, colIdx, editMode){
		var inputEl;
		var curCol = this.items[itemIdx][colIdx];
		var colInfo = this.getColInfo(colIdx);
		var colElement = $('<td></td>');
		colElement.attr('title', this.cols[colIdx].title);
		var isEditedCel = false;

		if (colInfo.alias)
			colElement.addClass('attrAlias_' + colInfo.alias);

		//If this is last, mark with css class
		if (colIdx + 1 == this.cols.length)
			colElement.addClass('sc_lastCol');
		
		//color
		if (this.mRecsStatus[itemIdx] == -1){
			colElement.addClass('sc_showDeleteCel');
		}else{
			if (this.mRecsStatus[itemIdx] == 1){
				colElement.addClass('sc_showAddCel');
			}else{
				if (this.mFieldStatus[itemIdx] !== undefined){
					var colStatus = this.mFieldStatus[itemIdx][colIdx];
					if (colStatus == 1){
						colElement.addClass('sc_showEditCel');
						isEditedCel = true;
					}
				}
			}
		}

		if ($('#sc_approvalmatrixStatus').val() == 'active') {
			if (sc_ApprovalMatrix.lastChangesDel.indexOf(sc_ApprovalMatrix.mRecsID[itemIdx]) != -1) {
				colElement.addClass('sc_showDeleteCel');
			} else {
				if (sc_ApprovalMatrix.lastChangesAdd.indexOf(sc_ApprovalMatrix.mRecsID[itemIdx]) != -1) {
					colElement.addClass('sc_showAddCel');
				} else {
					if (colInfo.colType == 'level') {
						if (sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]] != undefined) {
							if (sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.id] != undefined) {
								if (sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.id][0] != undefined) {
									colElement.addClass('sc_showEditCel');
									isEditedCel = true;
								}
							}
						}
					} else if (colInfo.colType == 'function') {
						if (sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]] != undefined) {
							if (sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.level.id] != undefined) {
								if (sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.level.id][colInfo.id] != undefined) {
									colElement.addClass('sc_showEditCel');
									isEditedCel = true;
								}
							}
						}
					} else if (colInfo.colType == 'attribute') {
						if (sc_ApprovalMatrix.oldValues.oldAttrs[sc_ApprovalMatrix.mRecsID[itemIdx]] != undefined) {
							if (sc_ApprovalMatrix.oldValues.oldAttrs[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.id] != undefined) {
								colElement.addClass('sc_showEditCel');
								isEditedCel = true;
							}
						}
					}
				}
			}
		}
		//Levels and functions
		if (colInfo.colType == 'level' || colInfo.colType == 'function'){
			colElement.attr('columnid', colIdx);
			colElement.addClass("sc_levelCol " + colInfo.oddEven);
			if (colInfo.type != 'signing' && colInfo.type != 'confirmation') {
				colElement.addClass("changeAvailable");
			}
			
			if(this.edsEnabled && colInfo.type=='signing'){
				secondElement = colElement.clone();
			}

			var dispStr = ($("#ShowOnlyChanges").prop('checked')) ? 'block' : 'none';
			var oldValue = [];
			var oldEDSValue = '';
			if (sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]] != undefined) {
				if (colInfo.colType == 'level') {
					if (sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.id] != undefined) {
						if (sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.id][0] != undefined) {
							oldValue = sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.id][0].performerList;
							oldEDSValue = sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.id][0].EDSValue;
						}
					}
				} else {
					if (sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.level.id] != undefined) {
						if (sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.level.id][colInfo.id] != undefined) {
							oldValue = sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.level.id][colInfo.id].performerList;
							oldEDSValue = sc_ApprovalMatrix.oldValues.oldLevels[sc_ApprovalMatrix.mRecsID[itemIdx]][colInfo.level.id][colInfo.id].EDSValue;
						}
					}
				}
			}
			var oldValueStr = '';
			if (oldValue != null) {
				for (var i = 0; i < oldValue.length; i++) {
					oldValueStr += '&#013;';
					oldValueStr += this.userModel.getUserByID(oldValue[i]).title;
				}
			}

			var oldEDSValueStr = '';
			for (var edsTypeIdx = 0; edsTypeIdx < this.edsDocTypeCodes.length; edsTypeIdx++){
				if(oldEDSValue==this.edsDocTypeCodes[edsTypeIdx].code){
					oldEDSValueStr = this.edsDocTypeCodes[edsTypeIdx].title;
				}
			}

			if (editMode){
				//TokenInput for user type fields, see jquery tokenInput plugin for docs
				inputEl = $('<input class="sc_user" id="colInput' + itemIdx + '_' + colIdx + '" />')
					.attr('zid', itemIdx + '_' + colIdx)
					.appendTo(colElement);
				inputEl.tokenInput(this.userModel2.items, {
					minChars: 1,
					animateDropdown: false,
					tokenDelimiter: this.multipleAttributesDelimiter,
					propertyToSearch: 'title',
					hintText: this.lang.modelHintText,
					noResultsText: this.lang.modelNoResult,
					searchingText: this.lang.modelSearching,
					prePopulate: this.userModel2.populateFromArray(curCol.performerList),
					tokenFormatter: function (item){
						return "<li><p title='" + item[this.propertyToSearch].replace(/'/g, "\\'") + "'>" + item[this.propertyToSearch] + "</p></li>"
					},
					onAdd: (colInfo.type=='signing')?this.onSignAdd:null,
					onDelete: (colInfo.type=='signing')?this.onSignDelete:null
