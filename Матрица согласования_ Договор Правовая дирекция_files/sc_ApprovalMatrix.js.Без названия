			partnerID = 0;
		}else{
			if (colInfo.alias == "partners_internal_op") {
				return alert(sc.lang.youCantSelectOpForFewPartners);
			} else {
				partnerID = 0;
			}
		}
		
		var direction = $(this).parent().parent().find('.attrAlias_direction').find('div').text()
		if (direction == undefined){
			direction = $(this).parent().parent().find('.attrAlias_direction').find('input').val();
		}
		var functions = $(this).parent().parent().find('.attrAlias_functions').find('div').text()
		if (functions == undefined){
			functions = $(this).parent().parent().find('.attrAlias_functions').find('input').val();
		}
		var category = $(this).parent().parent().find('.attrAlias_category').find('div').text()
		if (category == undefined){
			category = $(this).parent().parent().find('.attrAlias_category').find('input').val();
		}
		
		if (colInfo.alias == "direction") {
			colInfo.validValues = [];
			var keys = Object.keys(sc.dfc);
			for (var i = 0; i < keys.length; i++) {
				colInfo.validValues.push(keys[i]);
			}
		} else if (colInfo.alias == "functions") {
			colInfo.validValues = [];
			if (direction.split(sc.multipleAttributesDelimiter).length == 1 && direction.length > 0) {
				var keys = Object.keys(sc.dfc[direction]);
				for (var i = 0; i < keys.length; i++) {
					colInfo.validValues.push(keys[i]);
				}
				if (functions == "") {
					selectedItems = colInfo.validValues;
				}
			}
		} else if (colInfo.alias == "category") {
			colInfo.validValues = [];
			if (direction.split(sc.multipleAttributesDelimiter).length == 1 && direction.length > 0) {
				var funcs = functions.split(sc.multipleAttributesDelimiter);
				if (funcs.length > 0 && functions.length > 0) {
