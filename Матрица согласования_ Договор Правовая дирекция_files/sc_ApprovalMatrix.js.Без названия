	//Initiating block
	initiated: false,

	//Initiate all columns, get settings, type, and others...
	initCols: function (){
		var colIdx = 0;
		this.cols = [];

		for (colIdx; colIdx < this.attributes.length; colIdx++){
			this.cols.push(this.attributes[colIdx]);
			this.cols[colIdx].colType = 'attribute';
			//Replace some attributes validValues
			if (this.cols[colIdx].alias == 'document_type'){
				this.cols[colIdx].validValues = this.docTypes;
			}else if (this.isAttributeCheckbox(colIdx)){
				this.cols[colIdx].validValues = [this.lang.yes, this.lang.no];
			}
		}
		//For the right Math
		--colIdx;

		//Levels are visual separete by colors, only levels, functions got same color as level
		var colOddEven = 'odd';
		for (var levelIdx = 0; levelIdx < this.levels.length; levelIdx++){
			colOddEven = (colOddEven == 'odd') ? 'even' : 'odd';
			//If level have any function, go through each of them
			if (this.levels[levelIdx].functions.length){
				for (var functionIdx = 0; functionIdx < this.levels[levelIdx].functions.length; functionIdx++){
					this.cols.push(this.levels[levelIdx].functions[functionIdx]);
					++colIdx;
					this.cols[colIdx].colType = 'function';
					//Level info to function, just for convenience
					this.cols[colIdx].level = {
						id: this.levels[levelIdx].id,
						title: this.levels[levelIdx].title
					};

					//Dont forget, functions has same color as level
					this.cols[colIdx].oddEven = colOddEven;
				}
			}else{
				//Level hast any function, yes that could be to
				this.cols.push(this.levels[levelIdx]);
				++colIdx;
				this.cols[colIdx].colType = 'level';
				this.cols[colIdx].oddEven = colOddEven;
			}
		}
	},

	initFilters: function (){
		var colInfo;
		//Clear object
		for (var i = 0; i < this.cols.length; i++){
			colInfo = this.getColInfo(i);
			if (this.isAttributeBetweenType(i)){
				this.filter.colsFilterArray[i] = {from: [], to: []};
			}else if (colInfo.colType=='level' || colInfo.colType=='function'){
				this.filter.colsFilterArray[i] = {performerList: [], edsDocTypeCode: []};
			}else{
				this.filter.colsFilterArray[i] = [];
			}
		}
	},

	decoreCheckboxes: function (){
		for (var i = 0; i < this.items.length; i++){
			for (var j = 0; j < this.items[i].length; j++){
				if (this.isAttributeCheckbox(j)) {
					if (this.items[i][j] == "true") {
						this.items[i][j] = [this.lang.yes];
					} else if (this.items[i][j] == "false") {
						this.items[i][j] = [this.lang.no];
					} else {
						this.items[i][j] = [];
					}
				}
			}
		}
	},

	init: function (){
		var colInfo;

		this.initCols();
		this.decoreCheckboxes();
		this.initFilters();

		for (var i = 0; i < this.items.length; i++){
			//As it first time, we shoud fill all items as visible for filter purpose
			this.visibleItems.push(i);

			//Fill null fields with empty arrays
			for (var j = 0; j < this.items[i].length; j++){
				if (this.items[i][j] === null || this.items[i][j] === undefined){
					colInfo = this.getColInfo(j);

					if (colInfo.colType == 'level' || colInfo.colType == 'function'){
						this.items[i][j] = {
							performerList : []
						};
					}else{
						this.items[i][j] = [];
					}
				}
			}
		}

		this.initiated = true;
		return this;
