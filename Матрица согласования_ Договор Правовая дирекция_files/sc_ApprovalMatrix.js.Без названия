	//Action functions
	//This function return array of items prepared for save, and change flag that items was saved.
	getItemsJSON: function (){
		var retVal = [];

		this.isChangedItemsWasSave = true;

		//Each item
		for (var i = 0; i < this.items.length; i++){
			retVal[i] = [];
			//Each attribute and level
			for (var j = 0; j < this.items[i].length; j++){
				retVal[i][j] = {};
				//Complex field
/* 				if (this.cols[j].alias =='previously_signed'){
					for (var l =0; l< this.items[i][j].length; l++){
						this.items[i][j][l] = !!this.items[i][j][l];
					}
				}        */
				if(this.cols[j].id == -2){
					var tmpVal = this.items[i][j];
					if($.isArray(tmpVal) && typeof(tmpVal[0]) == 'string'){
						tmpVal = JSON.parse(tmpVal[0]);
					}else if(tmpVal == undefined){
						tmpVal = [];
					}

					retVal[i][j].val = tmpVal;
				}else{					
					if (this.isAttributeCheckbox(j)) {
						retVal[i][j].val = [];
						if (this.items[i][j][0] == this.lang.yes) {
							retVal[i][j].val = [true];
						} else if (this.items[i][j][0] == this.lang.no) {
							retVal[i][j].val = [false];
						}
					} else {
						retVal[i][j].val = this.items[i][j];
					}
				}

				retVal[i][j].type = this.cols[j].colType;
				retVal[i][j].id = this.cols[j].id;
				retVal[i][j].alias = this.cols[j].alias;

				if (retVal[i][j].type == 'function'){
					retVal[i][j].levelId = this.cols[j].level.id;
					retVal[i][j].functionId = this.cols[j].id;
				}

				if (retVal[i][j].type == 'level'){
					retVal[i][j].levelId = this.cols[j].id;
					//There are cant be level with function, otherwise it will be function
					retVal[i][j].functionId = 0;
				}

				if (this.mRecsID[i] === undefined){
					retVal[i][j].row = 0;
				}else{
					retVal[i][j].row = this.mRecsID[i];//NEW
				}
				if ( this.itemsEdit.indexOf(retVal[i][j].row) >= 0 ){
					retVal[i][j].action = 'edit'
				}
				if (this.mRecsID == 0){
					retVal[i][j].action = 'add'
				}
			}
		}

		return JSON.stringify(retVal);
	},

